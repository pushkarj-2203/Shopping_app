# ============ PriceWise Backend — environment ============
# Copy to .env and fill in. Never commit the real .env.

# ---- App ----
ENVIRONMENT=development           # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false                    # set true in production for structured logs

# ---- Security (REQUIRED in production) ----
# Generate: openssl rand -hex 32
SECRET_KEY=dev-insecure-change-me-please-0000000000000000000000000000
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
# Dev default is local SQLite (zero setup). Production example:
# DATABASE_URL=postgresql+asyncpg://pricewise:password@db:5432/pricewise
DATABASE_URL=sqlite+aiosqlite:///./pricewise.db

# ---- Cache / Redis ----
# Leave empty to use the in-process cache (single instance / dev).
# REDIS_URL=redis://redis:6379/0
REDIS_URL=
CACHE_TTL_SECONDS=86400

# ---- Rate limiting ----
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_CHAT=20/minute

# ---- AI / LLM cost control ----
# none = pure rule-based, ZERO per-call cost (default & recommended to start)
LLM_PROVIDER=none                 # none | anthropic | ollama
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MAX_TOKENS=512
LLM_MONTHLY_TOKEN_BUDGET=2000000  # hard global cap; 0 = unlimited
LLM_USER_DAILY_CALL_CAP=50

# ---- External data providers (optional; mock by default) ----
DATA_PROVIDER=mock                # mock | google_cse
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ENGINE_ID=

# ---- LLM Orchestration ----
OPENAI_API_KEY=
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
LLM_MODEL_STANDARD=claude-haiku-4-5-20251001
LLM_MODEL_DEEP=claude-sonnet-4-6
MAX_CONTEXT_TOKENS=8000
SUMMARIZE_THRESHOLD_TOKENS=3000
WORKING_MEMORY_TURNS=8
RAG_TOP_K=5
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY=0.5

# ---- Vector / embeddings (pluggable) ----
VECTOR_BACKEND=memory            # memory | pgvector (Supabase ships pgvector)
EMBEDDING_PROVIDER=local         # local (hash, $0) | openai
EMBEDDING_DIM=256
EMBEDDING_MODEL=text-embedding-3-small
